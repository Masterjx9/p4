{
  "name": "masterjx9/pp2p-core-sdk",
  "description": "PHP FFI SDK for the PP2P Rust core C ABI",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pp2p",
    "p2p",
    "ffi",
    "tor",
    "onion"
  ],
  "autoload": {
    "psr-4": {
      "Pp2p\\Core\\": "bindings/php/src/"
